{
  "name": "dsfr-data-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo dsfr-data — Web Components de dataviz pour sites gouvernementaux",
  "repository": {
    "type": "git",
    "url": "https://github.com/bmatge/dsfr-data.git"
  },
  "homepage": "https://bmatge.github.io/dsfr-data/specs/",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "server"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build --workspace=dsfr-data",
    "build:shared": "npm run build --workspace=@dsfr-data/shared",
    "build:app-ui": "npm run build --workspace=@dsfr-data/app-ui",
    "build:apps": "npm run build:app-ui && npm run build --workspace=@dsfr-data/app-favorites && npm run build --workspace=@dsfr-data/app-playground && npm run build --workspace=@dsfr-data/app-sources && npm run build --workspace=@dsfr-data/app-builder-ia && npm run build --workspace=@dsfr-data/app-builder && npm run build --workspace=@dsfr-data/app-builder-carto && npm run build --workspace=@dsfr-data/app-dashboard && npm run build --workspace=@dsfr-data/app-monitoring && npm run build --workspace=@dsfr-data/app-admin && npm run build --workspace=@dsfr-data/app-pipeline-helper && npm run build --workspace=@dsfr-data/app-grist-widgets",
    "validate:build-env": "npx tsx scripts/validate-build-env.ts",
    "build:all": "npm run validate:build-env && npm run build:shared && npm run build && npm run build:apps && npx tsx scripts/generate-examples-list.ts",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run build:all && npm run build:app && tauri build",
    "build:app": "node scripts/build-app.js",
    "build:server": "npm run build --workspace=@dsfr-data/server",
    "dev:server": "npm run dev --workspace=@dsfr-data/server",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "lint": "eslint 'packages/core/src/**/*.ts' 'apps/**/*.ts' 'packages/shared/**/*.ts' 'server/src/**/*.ts'",
    "lint:fix": "eslint --fix 'packages/core/src/**/*.ts' 'apps/**/*.ts' 'packages/shared/**/*.ts' 'server/src/**/*.ts'",
    "format:check": "prettier --check 'packages/core/src/**/*.ts' 'apps/**/*.ts' 'packages/shared/**/*.ts' 'server/src/**/*.ts'",
    "format": "prettier --write 'packages/core/src/**/*.ts' 'apps/**/*.ts' 'packages/shared/**/*.ts' 'server/src/**/*.ts'",
    "typecheck": "npm run typecheck --workspace=dsfr-data",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version && vite-node scripts/sync-versions.ts",
    "sync-versions": "vite-node scripts/sync-versions.ts",
    "generate-sri": "vite-node scripts/generate-sri.ts",
    "check:sri": "vite-node scripts/generate-sri.ts -- --check",
    "check:accents": "bash scripts/check-french-accents.sh",
    "release-publish": "npm run build:shared && npm run build && changeset publish"
  },
  "keywords": [
    "web-components",
    "dsfr",
    "dataviz",
    "gouvernement",
    "lit"
  ],
  "author": "",
  "license": "MIT",
  "overrides": {
    "qs": "6.15.2",
    "esbuild": "^0.28.1",
    "form-data": "4.0.6",
    "@web/dev-server-core": {
      "ws": "^7.5.11"
    },
    "jsdom": {
      "undici": "7.28.0"
    },
    "nodemailer": "9.0.3"
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5",
    "printWidth": 100,
    "tabWidth": 2,
    "semi": true,
    "bracketSpacing": true,
    "arrowParens": "always"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ],
    "*.{ts,js,json,md,html,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "undici": "^8.8.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^10.0.1",
    "@open-wc/testing": "^5.0.0",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.4",
    "@vitest/coverage-istanbul": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-lit": "^2.3.1",
    "eslint-plugin-security": "^4.0.1",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.10"
  }
}
