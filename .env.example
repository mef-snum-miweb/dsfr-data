# =============================================================================
# gouv-widgets - Variables d'environnement
# =============================================================================
# Copier ce fichier en .env et adapter les valeurs a votre environnement.
#
#   cp .env.example .env
#
# Les variables prefixees VITE_ sont injectees dans le frontend au build time.
# Les autres sont utilisees par Docker / les scripts de deploiement.
# =============================================================================

# ---------------------------------------------------------------------------
# Domaine de production
# ---------------------------------------------------------------------------
# Nom de domaine sur lequel l'application est deployee.
# Utilise par Traefik (docker-compose.yml) et les scripts de deploiement.
APP_DOMAIN=chartsbuilder.matge.com

# ---------------------------------------------------------------------------
# URL du proxy CORS (build-time)
# ---------------------------------------------------------------------------
# URL de base du proxy CORS pour les appels API en production.
# Propagee au build Docker via docker-compose `build.args` (cf. issue #168).
# Si non definie, le fallback en dur est 'https://chartsbuilder.matge.com'
# (le domaine de deploiement de reference — sera transforme en fail-fast
# pour les deploiements self-hosted dans une future PR de l'epic #168).
# En dev, cette variable est ignoree (le proxy Vite est utilise).
# VITE_PROXY_URL=https://chartsbuilder.matge.com

# ---------------------------------------------------------------------------
# URL de la librairie JS dans le code genere (build-time)
# ---------------------------------------------------------------------------
# URL de base pour les bundles dsfr-data dans le code HTML genere (builders).
# Propagee au build Docker via docker-compose `build.args` (cf. issue #168).
# Valeurs speciales :
#   "jsdelivr" (defaut si non defini) → https://cdn.jsdelivr.net/npm/dsfr-data@0/dist
#   "unpkg"                           → https://unpkg.com/dsfr-data@0/dist
#   "self"                            → ${VITE_PROXY_URL}/dist (self-hosted)
# Sinon, une URL custom (ex: https://cdn.example.com/dist).
# VITE_LIB_URL=unpkg

# ---------------------------------------------------------------------------
# JWT Secret (mode serveur uniquement)
# ---------------------------------------------------------------------------
# Cle secrete pour la signature des tokens JWT (mode serveur avec auth).
# Generee automatiquement par deploy-server.sh si absente.
# JWT_SECRET=

# ---------------------------------------------------------------------------
# MariaDB (mode serveur uniquement)
# ---------------------------------------------------------------------------
# Connexion a la base MariaDB. Les mots de passe sont generes automatiquement
# par deploy-server.sh si absents.
# DB_HOST=mariadb
# DB_PORT=3306
# DB_NAME=dsfr_data
# DB_USER=dsfr_data
# DB_PASSWORD=
# DB_ROOT_PASSWORD=

# ---------------------------------------------------------------------------
# Chiffrement des cles API (mode serveur uniquement)
# ---------------------------------------------------------------------------
# Cle AES-256-GCM pour chiffrer les api_key_encrypted dans la table connections.
# 64 caracteres hexadecimaux (32 bytes). Generer avec : openssl rand -hex 32
# Generee automatiquement par deploy-server.sh si absente.
# ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# CSRF Secret (mode serveur uniquement)
# ---------------------------------------------------------------------------
# Cle HMAC pour la generation/validation des tokens CSRF (csrf-csrf v4).
# Generer avec : openssl rand -hex 32
# Si non defini, fallback sur ENCRYPTION_KEY (portees disjointes, AES vs HMAC).
# CSRF_SECRET=

# ---------------------------------------------------------------------------
# SMTP - Envoi d'emails (mode serveur uniquement)
# ---------------------------------------------------------------------------
# Serveur SMTP pour l'envoi d'emails (verification, bienvenue).
# Par defaut, utilise le conteneur docker-mailserver sur ecosystem-network.
# Pas d'authentification requise depuis le reseau Docker interne.
# SMTP_HOST=mailserver
# SMTP_PORT=25
# SMTP_FROM=noreply@ecosysteme.matge.com
# APP_URL=https://chartsbuilder.matge.com

# ---------------------------------------------------------------------------
# Albert IA - Configuration serveur par defaut (Builder IA)
# ---------------------------------------------------------------------------
# Si ces variables sont definies, le Builder IA fonctionne sans que l'utilisateur
# ait besoin de configurer sa propre cle API. Le token reste cote serveur (jamais
# expose au client). L'utilisateur peut surcharger avec sa propre config.
#
# IMPORTANT : PAS de prefixe VITE_ pour eviter l'injection dans le bundle JS.
# Obtenir un token Albert : https://albert.api.etalab.gouv.fr
#
# IA_DEFAULT_API_URL=https://albert.api.etalab.gouv.fr/v1/chat/completions
# IA_DEFAULT_MODEL=albert-large
# IA_DEFAULT_TOKEN=
